# AgroMech RAG MVP defaults
APP_ENV=development
APP_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
WORKER_CONCURRENCY=1

# Auth and permissions
# MVP default: one administrator account. Role matrix remains a later extension.
AUTH_MODE=single_admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
AUTH_TOKEN_SECRET=change-me
SESSION_TTL_MINUTES=720

# Next.js frontend server-side adapter
AGROMECH_API_BASE_URL=http://127.0.0.1:8000
AGROMECH_ADMIN_USERNAME=admin
AGROMECH_ADMIN_PASSWORD=change-me

# Upload limits
UPLOAD_MAX_FILE_SIZE_MB=100
UPLOAD_MAX_IMAGE_SIZE_MB=20
UPLOAD_MAX_CONCURRENT=2
DOCUMENT_LIBRARY_MAX_SIZE_GB=5

# File storage
FILE_STORAGE_BACKEND=local
LOCAL_FILE_STORAGE_PATH=./storage/files
DOCUMENT_DELETE_MODE=soft_delete

# API, external service and task timeouts
API_REQUEST_TIMEOUT_SECONDS=60
DEPENDENCY_CONNECT_TIMEOUT_SECONDS=2
UPLOAD_TIMEOUT_SECONDS=300
INGESTION_TASK_TIMEOUT_SECONDS=1800
RETRIEVAL_TIMEOUT_SECONDS=30
LLM_REQUEST_TIMEOUT_SECONDS=120
EVALUATION_TASK_TIMEOUT_SECONDS=3600

# P0 ingestion decisions
TABLE_PDF_MODE=text_or_ocr
OCR_ENGINE=paddleocr
VISION_CONFIDENCE_THRESHOLD=0.55
MAX_QA_QUESTION_CHARS=2000
MAX_IMAGES_PER_QUESTION=1

# Evaluation
EVALUATION_RUNNER_MODE=cli
EVALUATION_DEFAULT_DATASET=curated-mvp

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agromech
POSTGRES_USER=agromech
POSTGRES_PASSWORD=agromech
DATABASE_URL=postgresql+psycopg://agromech:agromech@localhost:5432/agromech

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=agromech_chunks

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=agromech
GRAPH_MAX_HOPS=2

# Model services
MODEL_PROVIDER=bailian
BAILIAN_API_KEY=
LLM_MODEL=
EMBEDDING_MODEL=
RERANK_MODEL=
VISION_MODEL=

# Degradation policy
# Required for indexed docs and answer generation: Postgres, Milvus, embedding, LLM.
# Optional retrieval channels may degrade, but must be recorded in trace.
RETRIEVAL_DEGRADE_ON_OPTIONAL_CHANNEL_FAILURE=true
OPTIONAL_RETRIEVAL_CHANNELS=graph,vision,rerank
