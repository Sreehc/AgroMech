# AgroMech RAG MVP defaults
APP_ENV=development
APP_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
WORKER_CONCURRENCY=1

# Auth and permissions
# Users live in the database. Create the first admin after migrations with
# scripts/create-user.py; AUTH_TOKEN_SECRET signs bearer tokens.
AUTH_TOKEN_SECRET=change-me
SESSION_TTL_MINUTES=720

# Next.js frontend server-side adapter
AGROMECH_API_BASE_URL=http://127.0.0.1:8000

# Upload limits
UPLOAD_MAX_FILE_SIZE_MB=100
UPLOAD_MAX_IMAGE_SIZE_MB=20
UPLOAD_MAX_CONCURRENT=2
DOCUMENT_LIBRARY_MAX_SIZE_GB=5

# File storage
# Use local before OSS is ready. Switch to oss after creating the bucket.
FILE_STORAGE_BACKEND=local
LOCAL_FILE_STORAGE_PATH=./.agromech-data/storage/files
DOCUMENT_DELETE_MODE=soft_delete

# Aliyun OSS
OSS_REGION=cn-beijing
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_BUCKET=agromech-rag-dev-cn-beijing
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PREFIX=agromech/dev
OSS_SIGNED_URL_TTL_SECONDS=600
OSS_DOWNLOAD_SIGNED_URL_TTL_SECONDS=3600

# API, external service and task timeouts
API_REQUEST_TIMEOUT_SECONDS=60
DEPENDENCY_CONNECT_TIMEOUT_SECONDS=2
UPLOAD_TIMEOUT_SECONDS=300
INGESTION_TASK_TIMEOUT_SECONDS=1800
RETRIEVAL_TIMEOUT_SECONDS=30
LLM_REQUEST_TIMEOUT_SECONDS=120
EMBEDDING_TIMEOUT_SECONDS=30
VISION_TIMEOUT_SECONDS=60
RERANK_TIMEOUT_SECONDS=8
EVALUATION_TASK_TIMEOUT_SECONDS=3600

# P0 ingestion decisions
TABLE_PDF_MODE=text_or_ocr
OCR_PROVIDER=paddleocr
OCR_ENGINE=paddleocr
VISION_CONFIDENCE_THRESHOLD=0.55
MAX_QA_QUESTION_CHARS=2000
MAX_IMAGES_PER_QUESTION=1

# PostgreSQL
# Reuse ../infrastructure infra-core postgres. Do not start a project-local database.
# Ports should match ../infrastructure/env/.env.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=agromech
POSTGRES_USER=agromech
POSTGRES_PASSWORD=agromech
DATABASE_URL=postgresql+psycopg://agromech:agromech@127.0.0.1:5432/agromech

# RabbitMQ task dispatch
# DB ingest_tasks remains the source of truth; RabbitMQ wakes workers.
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/%2F
RABBITMQ_QUEUE=agromech.ingest
RABBITMQ_EXCHANGE=
RABBITMQ_ROUTING_KEY=agromech.ingest
RABBITMQ_PUBLISH_ENABLED=false
RABBITMQ_CONSUME_PREFETCH=1
RABBITMQ_RECONNECT_SECONDS=5

# Vector storage: Zvec
VECTOR_BACKEND=zvec
ZVEC_PATH=./.agromech-data/zvec
ZVEC_COLLECTION=agromech_chunks
ZVEC_BACKUP_PATH=./.agromech-data/backups/zvec
ZVEC_BACKUP_RETENTION_DAYS=7

# Embedding
EMBEDDING_PROVIDER=bailian
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_BACKOFF_SECONDS=1,2,4
EMBEDDING_VERSION=emb_202606231530_text-embedding-v4_1024_chunk-v1
CHUNK_PROFILE=chunk-v1

# Graph: currently disabled from the main product path.
# Set GRAPH_BACKEND=neo4j only when working on future Graph RAG experiments.
GRAPH_BACKEND=local
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=agromech
GRAPH_MAX_HOPS=2
GRAPH_SCHEMA_VERSION=graph-v1
GRAPH_AUTO_ACCEPT_RULE_CONFIDENCE=0.90
GRAPH_AUTO_ACCEPT_LLM_CONFIDENCE=0.85
GRAPH_REVIEW_MIN_CONFIDENCE=0.65

# Model services: Aliyun Bailian
MODEL_PROVIDER=bailian
BAILIAN_API_KEY=
BAILIAN_BASE_URL=
LLM_MODEL=qwen3.7-plus
LLM_FALLBACK_MODEL=qwen3.6-flash
VISION_MODEL=qwen3.7-plus
RERANK_MODEL=qwen3-rerank

# Rerank
RERANK_ENABLED=true
RERANK_TOP_K=30
FINAL_EVIDENCE_LIMIT=5
RERANK_DEGRADE_ON_FAILURE=true

# Retrieval degradation policy
# Required for indexed docs and answer generation: Postgres, Zvec, embedding, LLM.
# Optional retrieval channels may degrade, but must be recorded in trace.
RETRIEVAL_DEGRADE_ON_OPTIONAL_CHANNEL_FAILURE=true
OPTIONAL_RETRIEVAL_CHANNELS=vision,rerank

# Evaluation
EVALUATION_RUNNER_MODE=cli
EVALUATION_DEFAULT_DATASET=curated-mvp
EVALUATION_TARGET_QUESTION_COUNT=30
EVALUATION_TOP_K=5
EVALUATION_TARGET_TOP5_SOURCE_HIT_RATE=0.80
EVALUATION_TARGET_CITATION_ACCURACY=0.70
EVALUATION_TARGET_MODEL_CONFUSION_RATE=0.10
