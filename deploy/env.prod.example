APP_ENV=production
APP_HOST=0.0.0.0
API_PORT=8000

AGROMECH_BACKEND_IMAGE=ghcr.io/OWNER/REPO/agromech-backend:latest
AGROMECH_API_BIND=127.0.0.1:8000
# 必填：宿主 ./data 会挂载为容器 /app/.agromech-data。文件通过受控发布流程分发，不提交到 Git。
RETRIEVAL_BASELINE_PATH=/app/.agromech-data/release-evidence/curated-mvp-2026-07.json

AUTH_TOKEN_SECRET=replace-with-long-random-secret
SESSION_TTL_MINUTES=720

DATABASE_URL=postgresql+psycopg://agromech:replace-me@postgres-host:5432/agromech
POSTGRES_HOST=postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=agromech
POSTGRES_USER=agromech
POSTGRES_PASSWORD=replace-me

RABBITMQ_URL=amqp://agromech:replace-me@rabbitmq-host:5672/%2F
RABBITMQ_QUEUE=agromech.ingest
RABBITMQ_EXCHANGE=
RABBITMQ_ROUTING_KEY=agromech.ingest
RABBITMQ_PUBLISH_ENABLED=true
RABBITMQ_CONSUME_PREFETCH=1
RABBITMQ_RECONNECT_SECONDS=5

FILE_STORAGE_BACKEND=local
LOCAL_FILE_STORAGE_PATH=./.agromech-data/storage/files
DOCUMENT_DELETE_MODE=soft_delete

GRAPH_BACKEND=local
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=unused-when-graph-backend-local

MODEL_PROVIDER=bailian
EMBEDDING_PROVIDER=bailian
BAILIAN_API_KEY=replace-me
BAILIAN_BASE_URL=replace-me
LLM_MODEL=qwen3.7-plus
LLM_FALLBACK_MODEL=qwen3.6-flash
VISION_MODEL=qwen3.7-plus
RERANK_MODEL=qwen3-rerank
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024

OCR_TEXT_MODE=legacy
OCR_PROVIDER=paddleocr
OCR_ENGINE=paddleocr
PADDLEOCR_API_TOKEN=

RERANK_ENABLED=true
BM25_TOP_K=50
DENSE_TOP_K=50
RRF_K=60
RRF_DENSE_WEIGHT=1.0
RRF_BM25_WEIGHT=1.0
FUSION_TOP_K=30
RERANK_TOP_K=30
FINAL_EVIDENCE_LIMIT=5
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_MODEL=qwen3.6-flash
QUERY_REWRITE_TIMEOUT_SECONDS=10
MAX_IMAGES_PER_QUESTION=1
